// =============================================================================
// StarsAlign Studio · 星合工坊
// Prisma Schema — Phase 1 完整数据模型
//
// 设计原则:
//   1. 所有跨集复用对象（资产/媒体/Prompt/Style）都有版本化
//   2. Canvas / 3D / LoRA / 多语言 / 插件全部预留字段，不增加 Phase 1 工作量
//   3. Cost Ledger 与 GenerationAttempt 完整记录便于后期 ROI/抽卡率分析
//   4. Soft-delete 通过 deletedAt 实现，配合回收站 UI
// =============================================================================

generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  runtime                = "nodejs"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  previewFeatures        = ["fullTextSearchPostgres", "relationJoins"]
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// § 1. 身份与权限
// =============================================================================

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String     @unique
  displayName  String
  avatarUrl    String?
  passwordHash String
  locale       String     @default("zh-CN") // 多语言预留
  timezone     String     @default("Asia/Shanghai")
  status       UserStatus @default(ACTIVE)
  isAdmin      Boolean    @default(false) // 全局管理员（后台访问）
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  // 关系
  ownedProjects   Project[]           @relation("ProjectOwner")
  memberships     ProjectMember[]
  assignments     EpisodeAssignment[]
  generations     GenerationAttempt[] @relation("AttemptCreatedBy")
  costEntries     CostLedgerEntry[]
  opLogs          OperationLog[]
  invitationsSent Invitation[]        @relation("InvitationInviter")
  promptEdits     PromptEdit[]
  inspirationDrafts InspirationDraft[]

  @@index([deletedAt])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

// =============================================================================
// § 2. 项目与团队
// =============================================================================

model Project {
  id          String      @id @default(cuid())
  name        String
  description String?     @db.Text
  type        ProjectType
  aspect      String // "9:16" | "16:9" | "1:1"
  styleId     String? // → StyleProfile.id
  budgetCny   Decimal?    @db.Decimal(12, 2)
  startDate   DateTime?   @db.Date
  daysCount   Int? // 总天数（如"第 34 天"）

  // 默认 Provider 偏好（运行时可由后台覆盖）
  defaultVideoProviderId String? // 'seedance-2.0'
  defaultImageProviderId String? // 'nano-banana-pro'
  defaultLlmModel        String? // 'claude-sonnet-4-5'

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id])

  members  ProjectMember[]
  episodes Episode[]
  assets   Asset[]
  assetRelations AssetRelation[]
  scripts  Script[]
  media    MediaItem[]
  costs    CostLedgerEntry[]
  opLogs   OperationLog[]
  invites  Invitation[]
  inspirationDrafts InspirationDraft[]
  promptKnowledge   PromptKnowledge[] // H0(docs/07):项目私有知识条目(世界观等)
  style    StyleProfile?     @relation(fields: [styleId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([ownerId])
  @@index([deletedAt])
  @@index([type])
  @@map("projects")
}

enum ProjectType {
  AI_REAL // AI 真人短剧
  ANIM_3D // 3D 国漫
  ANIM_2D // 2D 动漫
  POSTER // 海报 / 宣传
  CUSTOM // 自定义
}

model ProjectMember {
  projectId String
  userId    String
  role      MemberRole
  modules   String[] // ['director','art','aigc','library','analytics']
  joinedAt  DateTime   @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

enum MemberRole {
  OWNER
  ADMIN
  LEADER
  MEMBER
  VIEWER
}

model Invitation {
  id          String           @id @default(cuid())
  projectId   String
  email       String
  role        MemberRole       @default(MEMBER)
  modules     String[]
  inviterId   String
  status      InvitationStatus @default(PENDING)
  token       String           @unique
  expiresAt   DateTime
  respondedAt DateTime?
  createdAt   DateTime         @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter User    @relation("InvitationInviter", fields: [inviterId], references: [id])

  @@index([projectId])
  @@index([email])
  @@map("invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

// =============================================================================
// § 3. 剧本与剧本分析
// =============================================================================

model Script {
  id          String       @id @default(cuid())
  projectId   String
  episodeId   String? // null = 整部剧本（项目级总剧本）；非 null = 单集
  title       String?
  content     String       @db.Text // 原始剧本全文
  contentHash String // SHA-256 去重
  language    String       @default("zh-CN")
  source      ScriptSource @default(UPLOAD)
  version     Int          @default(1)

  // 版本系统：
  //   isCurrent — 同 episode 内任意时刻只有一个 true（应用层 setCurrent 事务保证）
  //   lockedAt  — 锁定后不可修改/删除，仅可作为参考
  isCurrent Boolean   @default(false)
  lockedAt  DateTime?

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  episode  Episode?         @relation(fields: [episodeId], references: [id])
  analyses ScriptAnalysis[]
  scenes   Scene[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([episodeId, version])
  @@index([projectId])
  @@index([episodeId, isCurrent])
  @@map("scripts")
}

/// 灵感创作草稿 — 想法 → LLM 生成多集剧本(大纲 + 各集),独立于 Script(未绑 episode)
/// 通过剧本子模块"关联剧本"按钮 → script.upload(source=AI_GENERATED) 转正为某集正式剧本
model InspirationDraft {
  id        String  @id @default(cuid())
  projectId String
  title     String  @default("未命名灵感") // 剧名(LLM 生成或用户填)
  idea      String  @db.Text // 用户输入的想法 / 灵感
  params    Json    @default("{}") // {genre, targetEpisodes, lengthHint, tone}
  outline   Json? // [{number, title, synopsis}] 多集大纲
  episodes  Json    @default("[]") // [{number, title, content}] 各集已展开剧本
  status    String  @default("DRAFT") // DRAFT / OUTLINE_DONE / DONE
  pinned    Boolean @default(false) // 需求1d:顶置(最满意)— 只有顶置草稿能在剧本「关联剧本」选用
  modelId   String?
  createdBy String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([projectId, deletedAt])
  @@map("inspiration_drafts")
}

enum ScriptSource {
  UPLOAD
  AI_GENERATED
  IMPORTED
}

enum AnalysisScope {
  EPISODE // 单集分析(W2.7,scriptId 必填)
  PROJECT // 整剧批量分析(W6+,projectId 必填,scriptId=null)
}

model ScriptAnalysis {
  id String @id @default(cuid())

  // 维度 — 单集 / 整剧聚合（为 W6+ 批量分析预留）
  // scope=EPISODE → scriptId+episodeId 必填,projectId 任选
  // scope=PROJECT → projectId 必填,scriptId=null,episodeIds 存覆盖的集
  scope      AnalysisScope @default(EPISODE)
  scriptId   String?
  episodeId  String?
  projectId  String? // scope=PROJECT 时必填
  episodeIds String[]      @default([]) // scope=PROJECT 时覆盖的 episode.id 列表
  modelId    String // 'claude-sonnet-4-5' etc.

  // 8 维评分（单集为原始分,整剧为各集均值/加权）
  hookScore     Float?
  suspenseScore Float?
  twistScore    Float?
  climaxScore   Float?
  conflictScore Float?
  dialogueScore Float?
  paceScore     Float?
  urgencyScore  Float?
  overallScore  Float?

  // 整集 / 整剧 诊断
  summary    String? @db.Text
  highlights Json // [{ severity, type, text }]
  issues     Json // [{ severity, scene, type, suggestion }]

  // 剧情曲线（情绪强度 / 节奏 / 钩子 / 爽点）— 单集时间轴 0-N 秒
  curveJson Json // [{ time, emotion, beat, badges[] }]

  // 制作曲线（用于 AIGC 优先级派发）
  productionPlan Json // [{ sceneIdx, priority: 'S'|'A'|'B'|'C', durationS }]

  // [W6 预留] 各集对比数据快照,避免每次重算聚合
  // 形如 [{episodeId, episodeNumber, scores:{...}, beats:n}]
  perEpisodeStats Json?

  // [W6 预留] 整剧维度时的对比数据(如各集张力均值数组,stacked bar 8 维)
  comparisonJson Json?

  costCny    Decimal @db.Decimal(10, 4)
  durationMs Int     @default(0)

  script Script? @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  createdBy String

  @@index([scriptId])
  @@index([projectId, scope, createdAt])
  @@index([scope, createdAt])
  @@index([episodeId])
  @@map("script_analyses")
}

// =============================================================================
// § 4. 集与镜头
// =============================================================================

model Episode {
  id        String        @id @default(cuid())
  projectId String
  number    Int // 第几集（1-based）
  title     String?
  status    EpisodeStatus @default(NOT_STARTED)

  // 发布机制：分镜发布后 publishedAt 戳记 + 版本快照
  publishedAt      DateTime?
  publishedVersion Int       @default(0)

  // W3.1.followup 软锁：generateForEpisode 进入时戳 startedAt + 切 status=GENERATING；
  // try/finally 释放回原 status。startedAt 超过 SOFT_LOCK_TTL_MS 视为 stale,允许抢回。
  generatingStartedAt DateTime?

  // Phase 1.5.3:批量生成排除标记 — true 时,storyboard.generateForAllEpisodes / 全部集数生成 跳过本集
  // 区别于 generatingStartedAt 的瞬时软锁:这是用户手动设置的"永久跳过",直到手动解锁
  batchLocked Boolean @default(false)

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shots       Shot[]
  shotGroups  ShotGroup[]
  scenes      Scene[]
  scripts     Script[]
  assignments EpisodeAssignment[]
  assetUsages AssetUsageBinding[]
  renders     EpisodeRender[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([projectId, number])
  @@index([projectId])
  @@index([status])
  @@map("episodes")
}

enum EpisodeStatus {
  NOT_STARTED
  IN_PROGRESS
  GENERATING
  COMPLETED
  ARCHIVED
}

// =============================================================================
// EpisodeRender — 整集成片(M1 · 2026-06-10,蓝图 docs/06 §3 M1)
//
// 一次成片 = 按 group 首镜 positionIdx 串接各组「最新未拒成功 take」→ concat 统一 1080p
// → 字幕烧录(SRT 由台词正则 + ffprobe 实测时长生成)→ 可选 BGM ducking → 产物落 MediaItem。
// status 复用 AttemptStatus 枚举(只用 QUEUED/RUNNING/SUCCESS/FAILED 子集,不新增枚举)。
// paramsJson:{allowGaps, burnSubtitles, bgmMediaId?, gaps:[...], burnFallback?} 执行参数快照。
// =============================================================================
model EpisodeRender {
  id        String        @id @default(cuid())
  episodeId String
  status    AttemptStatus @default(QUEUED)

  mediaId    String? // 成片 MP4 的 MediaItem.id
  srtMediaId String? // 字幕 SRT 的 MediaItem.id(独立产物,烧录回退时仍可外挂)
  paramsJson Json
  errorMsg   String?
  createdBy  String

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId, createdAt])
  @@index([status])
  @@map("episode_renders")
}

model EpisodeAssignment {
  id        String     @id @default(cuid())
  episodeId String
  userId    String
  role      AssignRole

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now())

  @@unique([episodeId, userId, role])
  @@index([userId])
  @@map("episode_assignments")
}

enum AssignRole {
  OWNER // 主负责人
  COLLAB // 协作者
  REVIEWER // 审核人
}

model Shot {
  id             String  @id @default(cuid())
  episodeId      String
  sceneId        String? // 所属场（剧本场号，如 1-1）
  groupId        String? // 所属合并组；null=独立单镜
  number         String // 单镜编号 "1"/"2"/"3"...；合并组的 number 存在 ShotGroup
  framing        String? // 景别（特写/中景/全景...）
  angle          String? // 角度（平视/俯视/仰视 + 度数）
  // W1-W5 audit P1 followup:W7 4 大预设 framing/angle/movement/lighting 完整落库
  // movement = 运镜(固定/推/拉/摇/移/跟/升降/甩)、lighting = 光线(自然光/硬光/柔光/逆光...)
  // 跟 admin.preset.list 同源(PRESET_KINDS),UI 下拉框 + LLM 生成分镜时填值
  movement       String? // 运镜（与 admin.preset movement 联动）
  lighting       String? // 光线（与 admin.preset lighting 联动）
  // 六八:四维电影级分镜 — 音效设计(环境底/动效/强调三层,自由文本;LLM 生成 + 可手编,无预设)
  sound          String?
  // ADR-23(2026-05-24):预留 first/last frame 字段
  // Seedance 2.0 / Veo 3.1 / Wan 2.6 / Pika 2.0 已全部支持 FLF2V(first-last-frame to video)
  // Phase 1 不用,Phase 2 升级 I2V/FLF2V 时启用 — 零成本预留
  startFrameMediaId String? // → MediaItem.id,生成视频时作为首帧约束
  endFrameMediaId   String? // → MediaItem.id,生成视频时作为尾帧约束
  content        String  @db.Text // 镜头内容描述
  prompt         String  @db.Text // 视频提示词（含 @ 资产 + 台词 + OS）
  promptCompiled String? @db.Text // 编译后真实下发到模型的 prompt（snapshot）
  durationS      Float   @default(5) // 时长（秒）

  // 制作价值
  priority Priority? // S / A / B / C

  // 历史遗留：W1.6 算法的字段，新系统由 groupId 取代
  // 保留以避免破坏 mergeShots 算法的纯逻辑测试；线上不再写入
  isMerged   Boolean  @default(false)
  mergedFrom String[]

  // 位置（Linear 用 idx，Canvas Phase 3 用 x/y）
  positionIdx Int
  positionX   Float?
  positionY   Float?

  status ShotStatus @default(DRAFT)

  // 历史快照（用于 Diff 与回滚）
  versionHash String?

  episode     Episode             @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  scene       Scene?              @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  group       ShotGroup?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  /// @deprecated 用 assetUsages
  assets      ShotAssetRef[]
  assetUsages AssetUsageBinding[]
  attempts    GenerationAttempt[]
  // ADR-23:首尾帧 MediaItem 引用(Phase 2 用),onDelete: SetNull 防 media 删除影响 shot
  startFrame  MediaItem?          @relation("ShotStartFrame", fields: [startFrameMediaId], references: [id], onDelete: SetNull)
  endFrame    MediaItem?          @relation("ShotEndFrame",   fields: [endFrameMediaId],   references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ⚠️ 三十六收工 P0 修:DB 用 partial unique(WHERE deletedAt IS NULL),Prisma 7 @@unique 不支持 partial。
  // 见 migration `20260528000000_partial_unique_scenes_shots_groups_softdelete`。
  // 此处不写 @@unique 避免 migrate dev 试图改成普通 unique 破坏 soft-delete 防御。
  @@index([episodeId])
  @@index([sceneId])
  @@index([groupId])
  @@index([status])
  @@index([priority])
  // ADR-23:Phase 2 真用时按 mediaId 反向查 shot 引用,加索引避免全表扫
  @@index([startFrameMediaId])
  @@index([endFrameMediaId])
  @@map("shots")
}

enum ShotStatus {
  DRAFT
  PUBLISHED // 导演已发布给 AIGC
  QUEUED // 等待生成
  GENERATING
  GENERATED // 至少一个 candidate
  ADOPTED // 已采纳
  FINAL // 最终成片(剪辑模块已移除,此前的 IN_EDIT 状态已删除)
  FAILED
  BUDGET_BLOCKED
}

enum Priority {
  S // 顶级（爽点/反转）
  A
  B
  C // 过渡
}

model ShotAssetRef {
  id      String       @id @default(cuid())
  shotId  String
  assetId String
  refKind AssetRefKind @default(VISIBLE) // VISIBLE / MENTIONED / VOICE_ONLY

  shot  Shot  @relation(fields: [shotId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([shotId, assetId, refKind])
  @@index([assetId])
  @@map("shot_asset_refs")
}

enum AssetRefKind {
  VISIBLE // 画面中出现，需调用资产
  MENTIONED // 仅台词提及，不需调用
  VOICE_ONLY // 仅声音出现
}

// -----------------------------------------------------------------------------
// 资产出场绑定(W4-MM) — 三层结构 episode / scene / shot
//
// 替代 ShotAssetRef(只到 shot 级 + 3 档 refKind),完整表达"陆乘 在 第 14 集
// 第 2 场 出场,持有 灵泉水玉瓶"这种关系。
//
// 一个 Asset 可在同一 episode 内有多条 binding(出现在多 scene/shot)。
// episodeId 必填(产品需求:卡片底部"1-1 / 2-1 / 14-2"按集 group)。
// sceneId / shotId 可选(资产可"出现在某集"但还没排具体场/镜)。
// -----------------------------------------------------------------------------

model AssetUsageBinding {
  id        String @id @default(cuid())
  assetId   String
  projectId String

  episodeId   String // 必填:卡片 group by 用
  sceneId     String?
  shotGroupId String? // W5.1:AIGC 生成段级 binding(典型 1-8 这种 ShotGroup)
  shotId      String?

  usageType AssetUsageType @default(APPEAR)
  required  Boolean        @default(true) // 必须调用 / 可缺
  note      String?

  // W5.1:在 ShotGroup 内的稳定序号(1/2/3...),用于 UI 显示"图片N"/"音频N",
  // 视频提示词里的 @图片N / @音频N token 引用同一编号。
  // null 表示该 binding 还没分配 slot(蓝图阶段 / 历史数据)。
  //
  // ⚠️ L3(W5 P2 设计决策):槽位"只增不复用"
  //   autoMatch / bindAssetToGroup 用 `max(refSlotIdx) + 1` 续号,删 binding 后空缺不复用。
  //   例:绑了 1/2/3 → 删 2 → 下次新绑得 4,UI 显示 "@图片1 / @图片3 / @图片4"(跳号)。
  //   原因:复用空号会让历史 video attempts 的 inputJson.references 引用错位 — token "@图片2"
  //   今天指向 A,明天复用后指向 B,审计 / 重抽都会乱套。
  //   接受跳号 trade-off,前端 UI 不显示绝对编号(只显示资产名 + token),用户无感。
  refSlotIdx Int?

  asset     Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  episode   Episode    @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  scene     Scene?     @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  shotGroup ShotGroup? @relation(fields: [shotGroupId], references: [id], onDelete: SetNull)
  shot      Shot?      @relation(fields: [shotId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ⚠️ W1-W5 audit P0(D1)+ W5.1:复合 unique 含 nullable 列在 PG 中 NULL≠NULL,
  // 同 (陆乘,第14集,null,null,APPEAR) 会被双插;且 W5.1 加 shotGroupId 后维度数从 4 变 5。
  // 改为 partial functional unique index(COALESCE + WHERE deletedAt IS NULL),
  // 见 migration `20260523113000_w5_1_assetusage_shotgroup_refslot`(D1 的索引被 drop 重建为含 shotGroupId 的新版本)。
  // Prisma schema 此处不再写 `@@unique` 避免下次 migrate dev 试图恢复成原始版本。
  @@index([assetId])
  @@index([episodeId])
  @@index([sceneId])
  @@index([shotGroupId])
  @@index([shotId])
  @@index([projectId])
  @@index([shotGroupId, refSlotIdx]) // W5.1 UI:按 group 列出 bindings 时按 slot 排序
  // ⚠️ W5 audit S1:refSlotIdx 在同 shotGroup 内必须唯一(防 @图片1 重复)
  // 改为 partial unique index(WHERE shotGroupId IS NOT NULL AND refSlotIdx IS NOT NULL AND deletedAt IS NULL)
  // 见 migration `20260523150000_w5_audit_refslot_unique`。Prisma schema 不写 @@unique 避免 migrate dev 试图改成普通 unique。
  @@map("asset_usage_bindings")
}

enum AssetUsageType {
  APPEAR // 画面出现
  SPEAK // 角色说话
  HOLD // 手持道具
  WEAR // 身着服装/装饰
  ENVIRONMENT // 场景环境(背景空间)
  BACKGROUND // 仅作背景出现(无戏剧重点)
  SOUND_BG // 环境底噪(声音资产)
  SOUND_VOICE // 配音(声音资产)
  THEME // 主题音乐
  REFERENCE // 仅参考(不出现在画面)
}

// -----------------------------------------------------------------------------
// 场（剧本场号，如 `1-1 日 内 陆乘家破土屋`）
// 一集 ⊃ 多场 ⊃ 多镜
// -----------------------------------------------------------------------------

model Scene {
  id          String         @id @default(cuid())
  episodeId   String
  scriptId    String? // 来源剧本（便于跨版本回溯）
  number      String // "1-1" / "1-2"（集.场）
  timeOfDay   SceneTimeOfDay @default(DAY)
  location    SceneLocation  @default(INDOOR)
  place       String? // "陆乘家破土屋"
  characters  String[]       @default([]) // ["陆乘","陆萌萌"]（Phase 2 关联 Asset.id）
  content     String         @db.Text // 该场剧本原文
  positionIdx Int // 集内顺序

  episode     Episode             @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  script      Script?             @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  shots       Shot[]
  assetUsages AssetUsageBinding[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ⚠️ 三十六收工 P0 修:DB 用 partial unique(WHERE deletedAt IS NULL),Prisma 7 @@unique 不支持 partial。
  // 见 migration `20260528000000_partial_unique_scenes_shots_groups_softdelete`。
  // 此处不写 @@unique 避免 migrate dev 试图改成普通 unique 破坏 soft-delete 防御。
  @@index([episodeId])
  @@index([scriptId])
  @@map("scenes")
}

enum SceneTimeOfDay {
  DAWN // 晨
  DAY // 日
  DUSK // 昏
  NIGHT // 夜
}

enum SceneLocation {
  INDOOR // 内
  OUTDOOR // 外
  MIXED // 内外
}

// -----------------------------------------------------------------------------
// 镜头合并组（"1-8" 一段送给视频模型）
// 单镜 Shot.groupId 指向本表；可逆合并/拆分
// -----------------------------------------------------------------------------

model ShotGroup {
  id             String     @id @default(cuid())
  episodeId      String
  number         String // "1-8" / "9-18" / "1-8a"
  positionIdx    Int // 集内顺序
  durationS      Float      @default(0) // 组内 shots durationS 之和（缓存）
  prompt         String     @db.Text // 组级提示词（AI 一次性生成，含台词+OS）
  promptCompiled String?    @db.Text // 编译后下发的 prompt 快照
  status         ShotStatus @default(DRAFT)
  publishedAt    DateTime?

  episode  Episode             @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  shots    Shot[]
  bindings AssetUsageBinding[] // W5.1:group 级资产绑定(AIGC 生成段引用)
  attempts GenerationAttempt[] // W5.4:group 级视频生成尝试

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ⚠️ 三十六收工 P0 修:DB 用 partial unique(WHERE deletedAt IS NULL),Prisma 7 @@unique 不支持 partial。
  // 见 migration `20260528000000_partial_unique_scenes_shots_groups_softdelete`。
  // 此处不写 @@unique 避免 migrate dev 试图改成普通 unique 破坏 soft-delete 防御。
  @@index([episodeId])
  @@index([status])
  @@map("shot_groups")
}

// =============================================================================
// § 5. 数字资产（人物 / 场景 / 道具）
// =============================================================================

model Asset {
  id          String    @id @default(cuid())
  projectId   String
  type        AssetType
  name        String // 完整名:"陆乘 - 重生初期" / "陆乘 - 疗伤期"
  alias       String[] // 别名（自动 @ 匹配）
  description String?   @db.Text
  prompt      String    @db.Text // 基础提示词(人工/LLM 撰写,生成时与 StyleProfile 拼合)
  promptStep  Json? // 资产拆解多步链中间结果

  // 同一原型不同时期/变体的 key — 同 projectId 内同 archetypeKey 表示同一角色/场景/道具
  // 例:archetypeKey="陆乘" 下有"重生初期"和"疗伤期"两个 Asset
  archetypeKey String?

  // 资产成熟度 L0-L5(派生显示用,实际从槽位 + 状态算)
  maturity AssetMaturity @default(L0_IDENTIFIED)

  // 重要性分级(道具用,文档建议 S/A/B/C;人物可复用同字段表达戏份)
  importance String? // 'S' | 'A' | 'B' | 'C'

  // 角色身份(人物用)
  characterRole String?
  tags          String[]

  // ---- 剧本拆解角色档案(2026-06 P1:导演「剧本拆解」子模块的文字设定)----
  gender          String? // 'MALE' | 'FEMALE' | 'OTHER'(人物)
  age             Int? // 年龄
  heightCm        Int? // 身高 cm
  mbti            String? // MBTI(AI 深化 / 人工)
  personalityTags String[] @default([]) // 性格标签
  monologue       String?  @db.Text // 一句独白
  bio             String?  @db.Text // 人物小传(背景故事:家世/关键人生节点/动机弧光,五六-2 剧本拆解 LLM 生成 + 人工微调)
  episodes        Int[] @default([]) // 五七-3:出场集号(人物/场景/道具均用;据剧本 ===第N集=== 标记拆解;用于排序 + 标注出场)
  profileJson     Json? // 半结构化档案:人生节点 lifeNodes:[{year,title,desc}] + 声音/场景/道具特有设定
  // 同步闸(2026-06):剧本拆解文字定稿 → 同步到美术工坊。null=仅剧本拆解可见可编辑;
  //   非空=已同步,美术工坊显示+编辑(同步只翻转此闸不复制数据,故最终以美术工坊微调为准,剧本拆解侧只读)
  syncedToArtAt   DateTime?

  // 提示词风格继承
  styleId String? // → StyleProfile.id;null=随项目

  // ---- 命名槽位(W4-MM):每个槽位 = 一张已确认的 MediaItem ----
  // 人物
  portraitMediaId   String? // 9:16 正面形象
  threeViewMediaId  String? // 16:9 三视图(正/侧/背合一张)
  // 场景
  sceneMainMediaId  String? // 主视角(用户拍板的代表视图)
  sceneFrontMediaId String? // 正面视角
  sceneLeftMediaId  String? // 左侧视角
  sceneRightMediaId String? // 右侧视角
  sceneBackMediaId  String? // 背面视角
  panoramaMediaId   String? // 360° 全景
  // 道具 / 风格参考:用通用 mainMediaId

  // 兼容字段(W4-MM 前的 schema,新代码不用,留给历史数据兼容,W5 清理)
  /// @deprecated 用 portraitMediaId / sceneMainMediaId
  mainMediaId   String?
  /// @deprecated 用 threeViewMediaId
  threeViewIds  String[]
  /// @deprecated 用 panoramaMediaId
  panorama360Id String?

  refImageIds String[] // 参考图(用户上传,作为生成时的 reference)

  // Phase 2 预留
  loraIds      String[] @default([])
  voiceMediaId String? // 配音参考(保持不同剧集人物声音一致)
  voiceModelId String? // TTS voice_id(Phase 2)

  // Phase 3 预留 - 3D 一致性
  model3dUrl  String?
  gaussianUrl String?

  // 合规(人物专用)
  complianceId        String? // 火山/Seedance 返回的合规代码,后续视频生成复用
  complianceVendor    String? // 'seedance' / 'volcengine_face' / ...
  complianceStatus    ComplianceStatus @default(NOT_REQUIRED)
  complianceCheckedAt DateTime?
  complianceExpiresAt DateTime? // 部分平台合规码有有效期

  // 锁定 — 已确认资产不允许直接覆盖,改要走新版本
  lockedAt DateTime?

  status AssetStatus @default(DRAFT)

  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  style         StyleProfile?       @relation(fields: [styleId], references: [id])
  versions      AssetVersion[]
  /// @deprecated 用 usageBindings (AssetUsageBinding)
  bindings      ShotAssetRef[]
  usageBindings AssetUsageBinding[]
  relationsFrom AssetRelation[]     @relation("AssetRelationFrom")
  relationsTo   AssetRelation[]     @relation("AssetRelationTo")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([projectId, type])
  @@index([projectId, name])
  @@index([projectId, archetypeKey])
  @@index([deletedAt])
  @@map("assets")
}

/// 资产间关联(2026-06 P1:图2 右侧「关联人物 / 关联资产」)
/// 通用 from→to + 关系描述;世界观/金手指/地图(P4)出现后也复用此表
model AssetRelation {
  id            String    @id @default(cuid())
  projectId     String
  fromAssetId   String
  toAssetId     String
  relationLabel String?   @db.Text // 如 "前任搭档 / 唯一见其崩溃时刻之人"
  createdBy     String
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromAsset Asset   @relation("AssetRelationFrom", fields: [fromAssetId], references: [id], onDelete: Cascade)
  toAsset   Asset   @relation("AssetRelationTo", fields: [toAssetId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([fromAssetId])
  @@index([toAssetId])
  @@index([deletedAt])
  @@map("asset_relations")
}

enum AssetMaturity {
  L0_IDENTIFIED // 已识别(剧本拆出来,无设定)
  L1_PROMPT_READY // 提示词完成
  L2_CANDIDATE // 有候选图,未确认
  L3_MAIN_CONFIRMED // 主图已确认
  L4_CONSISTENCY_READY // 一致性补齐(三视图/多角度/声音)
  L5_PRODUCTION_READY // 可用于生产(含合规通过)
}

enum AssetType {
  CHARACTER
  SCENE
  PROP
  STYLE_REFERENCE // 风格参考（Phase 2 LoRA）
}

enum AssetStatus {
  DRAFT // 草稿
  CANDIDATE // 多候选生成中
  CONFIRMED // 已确认入资产库
  RETIRED // 已退役
}

enum ComplianceStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model AssetVersion {
  id           String   @id @default(cuid())
  assetId      String
  version      Int
  prompt       String   @db.Text
  mediaItemIds String[] // 这个版本生成的所有图
  generatedBy  String // userId
  cost         Decimal  @db.Decimal(10, 4)
  notes        String?

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([assetId, version])
  @@index([assetId])
  @@map("asset_versions")
}

// =============================================================================
// § 6. 媒体资产中台
// =============================================================================

model MediaItem {
  id         String     @id @default(cuid())
  projectId  String? // null = 公共库
  scope      MediaScope @default(PROJECT)
  kind       MediaKind
  filename   String
  mimeType   String
  sizeBytes  Int
  storageKey String // → StorageAdapter 解析
  cdnUrl     String? // CDN URL（Phase 2）

  // 元信息（kind 决定 Schema）
  meta Json // image: {w,h,format}; video: {w,h,duration,fps,codec}; audio: {duration,bpm,sampleRate,waveformPeaks}

  // W4-MM:派生字段,入库时算好便于查询/筛选
  aspectRatio String? // '9:16' / '16:9' / '1:1' / ...
  viewKind    String? // 'portrait' / 'three_view' / 'scene_main' / 'scene_front' / 'scene_left' / 'scene_right' / 'scene_back' / 'panorama' / 'main' / 'detail' / 'reference'

  // AI 自动标签 / 嵌入向量（Phase 2 用 pgvector）
  tags        String[] @default([])
  aiLabels    Json? // CLIP/CLAP 输出
  embeddingId String? // Phase 2 预留

  // 版权
  copyright       CopyrightStatus @default(UNKNOWN)
  copyrightSource String? // 'aigc' | 'upload' | 'netease' | ...

  // 来源追溯
  source    MediaSource @default(UPLOAD)
  sourceRef String? // GenerationAttempt.id / Asset.id / external url

  // 四二收工:资产归属类别(用户在素材库手动归类)
  // 值:'CHARACTER'(人物形象/声音)/ 'SCENE'(场景)/ 'PROP'(道具)/ 'OTHER'(其他)
  // 用字符串而非 Prisma enum 以避开跟 Asset.kind 的语义耦合 + 允许后续扩展
  assetCategory String?

  // 软删除 + 收藏 + 多版本
  isFavorited Boolean @default(false)
  parentId    String? // 衍生关系（降噪/混音版本）

  project  Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   MediaItem?  @relation("MediaVersion", fields: [parentId], references: [id])
  variants MediaItem[] @relation("MediaVersion")
  // ADR-23:首尾帧反向关系(Phase 2 用)
  shotsAsStartFrame Shot[] @relation("ShotStartFrame")
  shotsAsEndFrame   Shot[] @relation("ShotEndFrame")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([projectId, kind])
  @@index([scope, kind])
  @@index([deletedAt])
  @@index([aspectRatio, kind])
  @@index([assetCategory]) // 四二收工:素材库按资产类别筛选
  @@map("media_items")
}

enum MediaScope {
  PUBLIC
  PROJECT
  PERSONAL
}

enum MediaKind {
  IMAGE
  VIDEO
  AUDIO
  THREE_D // Phase 3
  OTHER
}

enum CopyrightStatus {
  UNKNOWN
  SELF_OWNED
  LICENSED
  RESTRICTED
  FORBIDDEN
}

enum MediaSource {
  UPLOAD
  AIGC
  IMPORTED
  EXTERNAL
}

// =============================================================================
// § 7. AIGC 生成尝试与抽卡
// =============================================================================

model GenerationAttempt {
  id          String  @id @default(cuid())
  shotId      String? // 可能 null（资产生成、剧本分析）
  shotGroupId String? // W5.4:AIGC 视频生成绑到 ShotGroup(1-8 这种生成段)
  assetId     String?
  projectId   String
  episodeId   String?

  // 调用信息
  providerId     String // 'seedance-2.0' / 'kling-1.5' / 'happyhorse-pro' / 'local-mock' / ...
  modelId        String
  action         GenerationAction // VIDEO / IMAGE / TEXT / AUDIO
  inputJson      Json // 编译后 prompt + refAssets snapshot
  outputMediaId  String? // 主输出 MediaItem
  outputMediaIds String[] // 多候选输出（如多张图）
  errorMsg       String?

  // W5.0:异步 Provider(Seedance 等)create→poll 模式的任务 ID。
  // 客户端轮询 / W5.3 BullMQ worker 用它回查 Provider 任务状态。
  //
  // W5 P2:(providerId, providerJobId) partial unique — 防 webhook / poll retry
  // 多次回写同 jobId 产生重复 SUCCESS。见 migration 20260523180000_w5_p2_providerjob_unique。
  providerJobId  String?

  // 计费
  inputUnits   Float   @default(0) // tokens / pixels / seconds
  outputUnits  Float   @default(0)
  unitPriceCny Decimal @db.Decimal(10, 6)
  costCny      Decimal @db.Decimal(10, 4)

  // 时间与状态
  status     AttemptStatus @default(QUEUED)
  startedAt  DateTime?
  finishedAt DateTime?
  durationMs Int?

  // W4-MM:候选定位 — 这次生成是申请成为某个 Asset 的某个 slot
  // 例:asset=陆乘, candidateForSlot='portrait'
  // 用户点"确认"则把 outputMediaId 写到 Asset.portraitMediaId
  candidateForSlot String? // 'portrait' / 'three_view' / 'scene_main' / 'scene_front' / ... / null

  // W4-MM:用户标记"删除"(对应"不满意的可以删除")— soft reject
  // 不真删 attempt,保留训练审计
  rejected   Boolean   @default(false)
  rejectedAt DateTime?
  rejectedBy String?

  // 采纳标记("废片中的可用片段")
  adopted   Boolean   @default(false)
  adoptedAt DateTime?
  adoptedBy String?

  // 关联抽卡（一次重抽群组）
  groupId String? // UUID 把同 shot 多次抽卡归组

  // M3c QC 质检(蓝图 docs/06 §M3):VLM 判官对成功视频 take 抽帧评分。
  // null = 未评(开关未开 / 旧数据 / 评分失败 — 失败明细在 qcJson.error)
  qcScore Float? // 0-100 总分(VLM 输出 clamp 后)
  qcJson  Json? // 评分明细 {dims:{clarity,promptAdherence,faceConsistency},drift,notes,judge,...} 或 {error}

  createdAt DateTime @default(now())
  createdBy String

  user      User             @relation("AttemptCreatedBy", fields: [createdBy], references: [id])
  shot      Shot?            @relation(fields: [shotId], references: [id], onDelete: Cascade)
  // W1-W5 audit 三轮 F1:改 SetNull,防未来误硬删 ShotGroup 抹掉 attempt 审计链路。
  // archiveGroup 走软删,不触发 FK,所以这里 SetNull 跟当前行为一致 + 防硬删兜底。
  shotGroup ShotGroup?       @relation(fields: [shotGroupId], references: [id], onDelete: SetNull)
  // Phase 1.5 P0-1:1 attempt 多条 ledger entry(PREPAY + REFUND),从 one-to-one 改 one-to-many
  costEntries CostLedgerEntry[]

  @@index([projectId])
  @@index([projectId, createdAt]) // r8 性能优化:insights / api-usage CSV 时间窗 query 高频用
  @@index([shotId])
  @@index([shotGroupId, action, status]) // W5.4:listVideoTakes 用
  @@index([groupId]) // F4 批量:batch-followup 每个终态按批次标签查重试数/完成判定(深审 F-5.4)
  @@index([providerId, status])
  @@index([createdBy, createdAt])
  @@index([episodeId, action, status]) // 三十九收工 perf:aigc.listEpisodes 集数总览首屏高频(episodeId IN + action=VIDEO + status=SUCCESS)
  @@map("generation_attempts")
}

enum GenerationAction {
  VIDEO
  IMAGE
  TEXT
  AUDIO
  COMPLIANCE
  ANALYSIS // 单集剧本分析
  BATCH_ANALYSIS // 整剧批量分析(W6+,可能一次跑 60+ 集 LLM)
}

enum AttemptStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  TIMEOUT
  CANCELLED
  BUDGET_BLOCKED
}

// =============================================================================
// § 8. 成本账本（Cost Ledger）
// =============================================================================

// Phase 1.5 P0-1:cost ledger 加 entryType 区分 NORMAL/PREPAY/REFUND/ADJUSTMENT
// 视频生成预扣 + 退还机制(参考 OpenAI 兼容中转站的预扣实测):创建 task 时写 PREPAY,完成时写 REFUND(负数)
enum LedgerEntryType {
  NORMAL     // 普通扣费(LLM / image / 不带预扣的 action)
  PREPAY     // 视频生成 task 创建时预扣(按 max_duration × 单价 估算)
  REFUND     // 退还(完成时退多扣 - 失败时全退 - costCny 为负数)
  ADJUSTMENT // 手动调整(admin 校对 / 异常补偿)

  @@map("ledger_entry_type")
}

model CostLedgerEntry {
  id        String  @id @default(cuid())
  userId    String
  projectId String?
  episodeId String?
  shotId    String?
  assetId   String?
  // Phase 1.5 P0-1:去掉 @unique 改 @@index,允许同 attempt 多条 entry(PREPAY + REFUND)
  attemptId String?

  providerId String
  modelId    String
  action     String // 'video.generate' | 'image.generate' | 'text.generate' | ...

  inputUnits   Float
  outputUnits  Float
  unitPriceCny Decimal @db.Decimal(10, 6)
  costCny      Decimal @db.Decimal(12, 4)

  // 成功与否影响 ROI 计算
  success Boolean

  // Phase 1.5 P0-1 字段
  entryType     LedgerEntryType @default(NORMAL)
  refundReason  String? // 'video_task_overcharge_refund' / 'video_task_failed_full_refund' / 'admin_adjustment' 等
  parentEntryId String? // REFUND/ADJUSTMENT 指向对应的 PREPAY/NORMAL — 自引用形成账目链

  // Phase 2 计费维度预留
  billingCycle String? // '2026-05' 月度归集
  plan         String? // 'subscription' | 'pay-as-you-go'

  user    User               @relation(fields: [userId], references: [id])
  project Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  attempt GenerationAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  parent  CostLedgerEntry?   @relation("LedgerEntryParent", fields: [parentEntryId], references: [id], onDelete: SetNull)
  children CostLedgerEntry[] @relation("LedgerEntryParent")

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([userId, createdAt])
  @@index([providerId, modelId, createdAt])
  @@index([billingCycle])
  @@index([attemptId])
  @@index([entryType])
  // ⚠️ 12 维深审:DB 用 partial unique (attemptId) WHERE entryType='REFUND'(防并发双退款,
  // 代码级幂等 refundPrepayForAttempt + advisory 锁之外的 DB 兜底)。Prisma 不支持 partial
  // @@unique,见 migration `20260610010000_refund_unique_per_attempt`;此处不写 @@unique
  // 避免 migrate dev 改成全量 unique 误伤 NORMAL/ADJUSTMENT 多条语义。
  @@map("cost_ledger_entries")
}

// =============================================================================
// § 9. 操作日志（审计与回收站）
// =============================================================================

model OperationLog {
  id         String  @id @default(cuid())
  actorId    String
  projectId  String?
  action     String // 'project.create' / 'shot.update' / 'asset.delete' / ...
  targetType String // 'project' / 'shot' / 'asset' / 'media' / ...
  targetId   String
  beforeJson Json?
  afterJson  Json?
  ip         String?
  userAgent  String?

  user    User     @relation(fields: [actorId], references: [id])
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@map("operation_logs")
}

// -----------------------------------------------------------------------------
// 提示词修改记录（PromptEdit）— 训练数据集源
//
// 用户对 AI 生成内容（提示词 / 景别 / 角度 / 内容）的每一次手动修改都记录在此。
// 未来用于 fine-tune：把 (剧本片段, AI 生成的 before) → (人改的 after) 当作监督样本。
//
// 与 OperationLog 区别：
//   - OperationLog 是通用审计，字段宽泛、混入其他 action（删除/复制/分配等）
//   - PromptEdit 专注于"AI 输出 → 人改"这一条数据流，schema 直接服务训练管线
// -----------------------------------------------------------------------------

model PromptEdit {
  id String @id @default(cuid())

  targetType PromptEditTarget // SHOT / SHOT_GROUP / SCENE
  targetId   String

  field    String // "prompt" / "framing" / "angle" / "content" / "dialog"
  before   String  @db.Text
  after    String  @db.Text
  diffNote String? // 用户可选填的"为什么改"

  // 上下文（便于训练时还原剧本环境）
  projectId String
  episodeId String?
  scriptId  String? // 当时使用的剧本版本

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([targetType, targetId])
  @@index([projectId, createdAt])
  @@index([episodeId, createdAt])
  @@index([field, createdAt])
  @@map("prompt_edits")
}

enum PromptEditTarget {
  SHOT
  SHOT_GROUP
  SCENE
  ASSET // W4 资产 description / prompt / name 编辑训练集
}

// =============================================================================
// § 10. 提示词模板 / 风格 / 预设
// =============================================================================

model PromptTemplate {
  id          String                  @id @default(cuid())
  category    PromptCategory
  slug        String // 'asset_step_base' / 'asset_step1_core' / 'asset_step_merge' / 'storyboard_main' / 'panorama_360' / ...
  name        String
  description String?
  content     String                  @db.Text
  varsJson    Json // 占位符元信息（类型/默认值/必填）
  modelHint   String? // 推荐模型
  versionTag  String                  @default("v1")
  isActive    Boolean                 @default(true)
  versions    PromptTemplateVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, versionTag])
  @@index([category, isActive])
  @@map("prompt_templates")
}

model PromptTemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  versionTag String
  content    String   @db.Text
  varsJson   Json
  changeLog  String?
  createdAt  DateTime @default(now())
  createdBy  String

  template PromptTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, versionTag])
  @@map("prompt_template_versions")
}

enum PromptCategory {
  ASSET_BREAKDOWN // 资产拆解
  IMAGE_GENERATION // 图像生成
  SHOT_GENERATION // 镜头生图
  SCRIPT_STORYBOARD // 剧本分镜
  PANORAMA_360 // 360 全景
  PROMPT_FRAGMENT // 复用片段
  PROMPT_PRESET // 预设组合（景别/机位/运镜/光线等）
  PROMPT_OPTIMIZER // M6 动态 prompt 优化器 meta-prompt(按目标 provider 自适应)
}

// =============================================================================
// § 10.5 Prompt Mini-Harness 八维知识库(H0,docs/07 §3)
// =============================================================================

/// 八要素维度(docs/07 §1 — 时间轴是编译期结构段不入库,节奏类规则归 CAMERA)
enum PromptDimension {
  SUBJECT // 主体(锚定/外观规则)
  ACTION // 动作(抽象词→具体画面翻译对/微观死磕)
  SCENE // 场景(氛围/年代具体化;项目世界观 = projectId 作用域条目,D-E)
  LIGHTING // 光影
  CAMERA // 镜头语言(运镜语法/轴线/节奏切片规则)
  STYLE // 风格
  QUALITY // 画质强化词
  CONSTRAINT // 约束/稳定强化词
}

enum PromptKnowledgeSource {
  SEED // 种子语料(文章 + v2 模板蒸馏,db:sync 按 slug 增量补)
  MANUAL // admin 手录
  MINED // H3 飞轮蒸馏(PromptEdit 人改 / QC 失败模式沉淀,经 admin 审核)
}

/// 单表多维(D-A:不做 8 个物理库;不复用 PromptTemplate — 无 embedding/tags/projectId)
model PromptKnowledge {
  id        String          @id @default(cuid())
  dimension PromptDimension
  /// 种子条目锚(db:sync insert-if-missing 用);MANUAL/MINED 条目可空
  slug      String?         @unique
  title     String
  content   String          @db.Text
  /// { family?: string[], style?: string[], mood?: string[], era?: string[], keywords?: string[] }
  /// 空对象/键缺失 = 通用条目(任何过滤都命中)— 形状见 core/prompt-knowledge/retrieval.ts
  tagsJson  Json            @default("{}")
  /// number[] 懒回填(docs/07 §4.5:seed/db:sync 离线可跑,首次检索批量补算);null = 未算
  embedding Json?
  /// 算该向量用的 embedding 模型 id — 换模型后据此识别旧向量重算(维数/语义空间不可混)
  embeddingModel String?
  /// null = 全局;非空 = 项目私有(世界观年代设定即项目级场景维条目,D-E)
  projectId String?
  source    PromptKnowledgeSource @default(SEED)
  enabled   Boolean         @default(true)
  /// 飞轮数据(H3):检索命中计数 / 最近使用 — 权重升降依据
  hitCount   Int       @default(0)
  lastUsedAt DateTime?
  /// H3 飞轮权重:run.fragmentIds × 后续 qcScore 相关性升降(clamp 0.2-2,起始 1)。
  /// 检索排序的次级信号(tag 模式主排序;embedding/keyword 模式平分破并列)
  weight     Float     @default(1)
  createdBy  String?

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dimension, enabled])
  @@index([projectId])
  @@map("prompt_knowledge")
}

/// H2(docs/07 §3):优化运行记录 — 八维体检报告 / 审计 / H3 飞轮数据源。
/// 纯 id 关联无 FK(同 PromptEdit 模式 — 审计行不阻塞业务行删除)。
model PromptOptimizeRun {
  id        String  @id @default(cuid())
  groupId   String
  episodeId String
  projectId String
  userId    String
  /// 阶段明细:[{stage:'composer'|'judge'|'repair', modelId, inputTokens, outputTokens, costCny, targets?}]
  stagesJson Json
  /// 判官八维评分 {SUBJECT:{score,issue},...};判官缺席(未配 binding/失败)null
  dimScoresJson Json?
  /// 知识片段命中 id(composer 注入 ∪ repair 注入)— H3 与 qcScore 做相关性
  fragmentIds String[]
  /// repair 轮数(≤2,D-F)
  iterations Int     @default(0)
  /// 是否写回成功(false = deny / 乐观锁让位)
  applied    Boolean @default(false)
  /// deny 时的代码(HARD_GATE/TOKEN_LOST/…);applied=true 时 null
  denyCode   String?
  totalCostCny Decimal @default(0) @db.Decimal(12, 4)
  createdAt  DateTime @default(now())

  @@index([groupId, createdAt])
  @@index([episodeId])
  @@index([projectId, createdAt])
  @@map("prompt_optimize_runs")
}

model StyleProfile {
  id              String    @id @default(cuid())
  name            String // 'AI 真人' / '3D 国漫' / '2D 动漫'
  slug            String    @unique // 'ai_real' / 'anim_3d' / 'anim_2d'
  kind            StyleKind
  characterPrompt String    @db.Text
  scenePrompt     String    @db.Text
  propPrompt      String    @db.Text
  forbiddenWords  String[]
  isBuiltIn       Boolean   @default(false)

  // Phase 2 预留：Style Vector
  embeddingId String?

  projects Project[]
  assets   Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("style_profiles")
}

enum StyleKind {
  AI_REAL
  ANIM_3D
  ANIM_2D
  CUSTOM
}

// =============================================================================
// § 11. Provider 配置（API + 单价 + 并发）
// =============================================================================

model ProviderConfig {
  id          String       @id @default(cuid())
  providerId  String       @unique // 'seedance-2.0' / 'nano-banana-pro' / ...
  displayName String
  kind        ProviderKind
  apiUrl      String?
  isActive    Boolean      @default(true)

  // ---------- API Key 存储 ----------
  // 优先从 DB 读取（apiKeyEnc 经 AES-256-GCM 加密，解密用 APP_MASTER_KEY）
  // 若 DB 为空则 fallback 到环境变量 apiKeyRef
  apiKeyEnc       String? // base64(iv|tag|ciphertext)
  apiKeyMasked    String? // '••••XYZ7' — UI 显示用，不含明文
  apiKeyUpdatedAt DateTime?
  apiKeyUpdatedBy String? // userId
  apiKeyRef       String? // 环境变量名（fallback / 私有部署应急通道）

  // 计费规则
  unitPriceCny Decimal @db.Decimal(10, 6)
  unitName     String // 'second' | 'image' | 'ktoken' | 'request'

  // Phase 1.5 P0-2:2 倍率拆分(主次重审 v2.1 — cache/group 推 Phase 2)
  // 当 modelRate 非空时优先用 2 倍率公式:
  //   inputCost  = inputUnits  / 1_000_000 × modelRate
  //   outputCost = outputUnits / 1_000_000 × modelRate × (outputRate ?? 1)
  // 否则 fallback 到旧的 unitPriceCny 单价模式(向后兼容)
  modelRate  Decimal? @db.Decimal(10, 6) // 基础倍率 / 1M tokens(CNY)
  outputRate Decimal? @db.Decimal(10, 4) // 输出价 = 输入 × 此倍率(典型 2x-5x)

  // 并发与限流
  maxConcurrent Int @default(5)
  rateLimitRpm  Int @default(60)

  // 默认参数（max_duration, default_quality 等）
  defaultParams Json?

  // 健康度（Phase 2 自动 failover）
  healthScore Float     @default(1.0)
  lastErrorAt DateTime?

  // Phase 1.5.1(2026-05-25):中转站凭证关联
  // - relayProviderId 非空:此 Provider 走中转站(apiKey/apiUrl 从 RelayProvider 继承,ProviderConfig 自己的不用)
  // - relayProviderId null:直连 Provider(apiKey/apiUrl 在 ProviderConfig 上独立配)
  relayProviderId String?
  relayProvider   RelayProvider? @relation(fields: [relayProviderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([relayProviderId])
  @@map("provider_configs")
}

// =============================================================================
// § 12. 中转站凭证(Phase 1.5.1 · 2026-05-25)
// =============================================================================

/**
 * 中转站凭证 — 1 token 共享多模型
 *
 * 设计目标:
 *   - moyu / Poe / OpenRouter / OneAPI 自部署 等多中转站独立管理
 *   - 1 个凭证 = 1 个 apiUrl + 1 个 token,关联多个 ProviderConfig(via relayProviderId FK)
 *   - 用户在 admin UI 切换激活中转站 + 显式选择启用哪些模型
 *
 * 跟 ProviderConfig 关系:
 *   - 中转站模型:ProviderConfig.relayProviderId 非空,apiKey/apiUrl 从此表继承
 *   - 直连模型:ProviderConfig.relayProviderId null,自己存 apiKey/apiUrl
 *
 * catalogKey 关联静态 catalog(packages/shared/data/relay-catalogs.json)
 *   - 'moyu' / 'poe' / 'openrouter' 等已知中转站
 *   - null:自定义中转站(用户输入 apiUrl + 选模型)
 */
model RelayProvider {
  id              String    @id @default(cuid())
  name            String    @unique // 'moyu' / 'poe' / 'openrouter' / 'custom-xxx'
  displayName     String    // 用户可见名,可改('moyu.info' / 'Poe' / 'OpenRouter')
  apiUrl          String?   // base URL — 用户必填,seed 默认空
  catalogKey      String?   // 关联静态 catalog 的 key('moyu' / 'poe' / 'openrouter' / null=custom)

  // ---------- 凭证 ----------
  apiKeyEnc       String?   // AES-256-GCM base64(iv|tag|ciphertext)
  apiKeyMasked    String?   // UI 显示用('sk-XX••••••••XXXX')
  apiKeyUpdatedAt DateTime?
  apiKeyUpdatedBy String?   // userId

  isActive        Boolean   @default(true)
  notes           String?   // 用户备注(如"主用 / 备用 / ¥10 额度")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  providers       ProviderConfig[]

  @@map("relay_providers")
}

// =============================================================================
// § 14. 系统设置（全局 KV 表）
// =============================================================================

/**
 * 系统级 KV 配置
 * 用法示例:
 * - 默认 UI 语言: { key: 'system.locale.default', value: 'zh-CN' }
 * - 默认水印文字: { key: 'system.watermark.text', value: '星垣工坊' }
 * - 默认抽卡上限: { key: 'system.gacha.max_attempts', value: 5 }
 * 敏感字段用 isSecret 标记，UI 展示时脱敏；存储时与 APP_MASTER_KEY 加密。
 */
model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  category    String   @default("general")
  // W7 audit R3:实际使用的 category 字典(请保持同步):
  //   'general'        — 通用业务参数(storyboard.maxDurationS / shot.video.* 等)
  //   'security'       — 安全 / 认证开关(auth.allowSignup 等)
  //   'branding'       — 品牌(system.brand.* 等)
  //   'feature_flag'   — 功能开关(asset.compliance.requireForVideo 等)
  //   'model_binding'  — 模型用途绑定(binding.* — W3 加,见 admin.binding)
  //   'preset'         — UI 预设字典(preset.framing/angle/movement/lighting — W7 加,见 admin.preset)
  // 新增 category 必须在此注释 + 在 admin.system 端通过 zod enum 校验
  description String?
  isSecret    Boolean  @default(false)
  updatedBy   String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
  @@map("system_settings")
}

enum ProviderKind {
  VIDEO
  IMAGE
  TEXT
  AUDIO
  COMPLIANCE
  EMBEDDING
}

// =============================================================================
// § 12. 通知与评论（Phase 2 评论锚定预留）
// =============================================================================

model Notification {
  id      String  @id @default(cuid())
  userId  String
  type    String // 'invite' | 'mention' | 'budget_warn' | 'compliance_alert'
  title   String
  body    String?
  payload Json?
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

// =============================================================================
// § 13. 工作报告快照（Phase 1 可由查询动态算；本表用于历史归档）
// =============================================================================

model WorkReportSnapshot {
  id               String   @id @default(cuid())
  projectId        String?
  periodStart      DateTime
  periodEnd        DateTime
  gachaRatio       Float // 项目总抽卡率 (生成总时长 / 目标时长)
  targetSeconds    Float
  generatedSeconds Float
  perUserJson      Json // [{userId, role, video, image, audio, ops, gacha, output_target}]
  topGachaShots    Json // [{shotId, shotNumber, targetS, generatedS, count, ratio}]

  createdAt DateTime @default(now())

  @@index([projectId, periodEnd])
  @@map("work_report_snapshots")
}
