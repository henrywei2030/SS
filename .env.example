# =============================================================================
# StarsAlign Studio · 星垣工坊 — 环境变量样板
# 复制到 .env.local 并填入真实值。请勿提交 .env.local 到 Git。
#
# 重要说明：
#   - AI Provider API Keys（Seedance / 豆包 / Nano Banana / GPT Image 等）
#     建议通过 Admin 后台界面录入，加密存储到数据库。
#     env 变量仅作 fallback / 私有部署应急通道，原型期可全部留空。
# =============================================================================

# ----- 运行环境 -----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- 加密与签名密钥（生产环境必填，开发可临时随机） -----
# JWT 签名密钥：openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
# 应用主密钥（用于加密数据库里的 API Key 等敏感字段）
# 生成命令：openssl rand -hex 32
# ⚠️ 一旦设置不要轻易更换——更换后已存的加密数据无法解密
APP_MASTER_KEY=

# ----- 数据库 (Phase 1: 本地 Postgres) -----
DATABASE_URL=postgresql://ss_user:ss_pass@localhost:5432/starsalign?schema=public

# ----- Redis (BullMQ + Cache) -----
REDIS_URL=redis://localhost:6379

# ----- 对象存储 (Phase 1: MinIO 本地；Phase 2 切 R2/OSS) -----
STORAGE_DRIVER=minio           # minio | local-fs | r2 | oss | s3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=ss_minio_user
S3_SECRET_KEY=ss_minio_password
S3_BUCKET=starsalign
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ----- 事件总线 (Phase 1: 进程内；Phase 2 切 NATS) -----
EVENT_BUS_DRIVER=in-process    # in-process | nats

# =============================================================================
# AI Provider API Keys  (★ 推荐：通过后台 Admin UI 填入，加密存储到数据库 ★)
# =============================================================================
# 以下 env 变量仅作 fallback：私有部署或紧急情况下使用。
# 系统优先从 ProviderConfig 表读取 apiKeyEnc（用 APP_MASTER_KEY 解密）；
# 仅当数据库无 key 时才退回到这里。原型期可全部留空。
#
# Provider 列表（已通过 seed.ts 灌入数据库）：
#   - seedance-2.0 / seedance-2.0-fast   视频 (Seedance)
#   - doubao-1-5-pro-256k                 资产拆解 (豆包)
#   - nano-banana-pro                     图片
#   - gpt-image-2                         图片（全景/海报）
#   - claude-sonnet-4-5                   剧本分析
#   - volcengine-compliance               人物合规
# =============================================================================

SEEDANCE_API_KEY=
DOUBAO_API_KEY=
NANO_BANANA_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
VOLCENGINE_COMPLIANCE_API_KEY=

# ----- Hocuspocus (Y.js 协作服务器) -----
HOCUSPOCUS_URL=ws://localhost:1234
HOCUSPOCUS_SECRET=change-me

# ----- 可观测（Phase 2 启用） -----
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# SENTRY_DSN=

# ----- Phase 2 预留 -----
# STRIPE_SECRET_KEY=
# ALIPAY_APP_ID=
# WECHAT_PAY_MCH_ID=
