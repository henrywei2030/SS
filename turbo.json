{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.local"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "S3_ENDPOINT",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_BUCKET",
    "SEEDANCE_API_KEY",
    "DOUBAO_API_KEY",
    "NANO_BANANA_API_KEY",
    "VOLCENGINE_COMPLIANCE_API_KEY",
    "ANTHROPIC_API_KEY",
    "OPENAI_API_KEY",
    "JWT_SECRET",
    "NEXT_PUBLIC_APP_URL",
    "STORAGE_DRIVER",
    "EVENT_BUS_DRIVER"
  ],
  "tasks": {
    "@ss/db#generate": {
      "outputs": ["src/generated/**"],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "@ss/db#generate"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@ss/db#generate"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "@ss/db#generate"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "@ss/db#generate"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
